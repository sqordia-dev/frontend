{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "generate-api": "node scripts/generate-api.js",
    "generate-api:v1": "node scripts/generate-api.js v1",
    "generate-api:v2": "node scripts/generate-api.js v2",
    "generate-api:direct": "nswag run nswag.json",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:report": "playwright show-report",
    "test:e2e:auth": "playwright test --grep @auth",
    "test:e2e:dashboard": "playwright test --grep @dashboard",
    "test:e2e:admin": "playwright test --grep @admin",
    "test:e2e:billing": "playwright test --grep @billing",
    "test:e2e:cms": "playwright test --grep @cms",
    "test:e2e:questionnaire": "playwright test --grep @questionnaire",
    "test:e2e:public": "playwright test --grep @public",
    "test:e2e:profile": "playwright test --grep @profile",
    "test:e2e:smoke": "playwright test --grep @smoke --project=chromium",
    "test:e2e:critical": "playwright test --grep @critical",
    "test:e2e:visual": "playwright test --project=visual-regression",
    "test:e2e:visual:update": "playwright test --project=visual-regression --update-snapshots",
    "test:e2e:staging": "cross-env TEST_ENV=staging playwright test",
    "test:e2e:local": "cross-env TEST_ENV=local playwright test",
    "test:e2e:debug": "cross-env PWDEBUG=1 playwright test --headed",
    "test:e2e:trace": "playwright test --trace=on"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/signalr": "^10.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@number-flow/react": "^0.6.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.3.2",
    "@tanstack/react-query": "^5.90.21",
    "@tiptap/extension-link": "^3.17.0",
    "@tiptap/extension-placeholder": "^3.17.0",
    "@tiptap/extension-underline": "^3.17.0",
    "@tiptap/react": "^3.17.0",
    "@tiptap/starter-kit": "^3.17.0",
    "@types/canvas-confetti": "^1.9.0",
    "axios": "^1.12.2",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-flag-icons": "^1.6.4",
    "docx": "^9.5.1",
    "dompurify": "^3.3.2",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.29.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.344.0",
    "marked": "^17.0.3",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "qrcode.react": "^4.2.0",
    "quill": "^2.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.1",
    "react-quill": "^2.0.0",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.7.0",
    "region-flags": "^1.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.58.2",
    "@types/dompurify": "^3.0.5",
    "@types/file-saver": "^2.0.7",
    "@types/marked": "^5.0.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "cross-env": "^10.1.0",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "nswag": "^14.6.3",
    "playwright": "^1.58.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-svgr": "^4.5.0"
  }
}
