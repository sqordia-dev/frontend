(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\r\n\r\n.transition-colors {\n  transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\r\n\r\n.transition-opacity {\n  transition-property: opacity;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\r\n\r\n.transition-shadow {\n  transition-property: box-shadow;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\r\n\r\n.transition-transform {\n  transition-property: transform;\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  transition-duration: 150ms;\n}\r\n\r\n.duration-100 {\n  transition-duration: 100ms;\n}\r\n\r\n.duration-150 {\n  transition-duration: 150ms;\n}\r\n\r\n.duration-200 {\n  transition-duration: 200ms;\n}\r\n\r\n.duration-300 {\n  transition-duration: 300ms;\n}\r\n\r\n.duration-500 {\n  transition-duration: 500ms;\n}\r\n\r\n.duration-700 {\n  transition-duration: 700ms;\n}\r\n\r\n.ease-in-out {\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n}\r\n\r\n.ease-linear {\n  transition-timing-function: linear;\n}\r\n\r\n.ease-out {\n  transition-timing-function: cubic-bezier(0, 0, 0.2, 1);\n}\r\n\r\n.ease-smooth {\n  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n}\r\n\r\n@keyframes enter {\r\n\r\n  from {\n    opacity: var(--tw-enter-opacity, 1);\n    transform: translate3d(var(--tw-enter-translate-x, 0), var(--tw-enter-translate-y, 0), 0) scale3d(var(--tw-enter-scale, 1), var(--tw-enter-scale, 1), var(--tw-enter-scale, 1)) rotate(var(--tw-enter-rotate, 0));\n  }\n}\r\n\r\n@keyframes exit {\r\n\r\n  to {\n    opacity: var(--tw-exit-opacity, 1);\n    transform: translate3d(var(--tw-exit-translate-x, 0), var(--tw-exit-translate-y, 0), 0) scale3d(var(--tw-exit-scale, 1), var(--tw-exit-scale, 1), var(--tw-exit-scale, 1)) rotate(var(--tw-exit-rotate, 0));\n  }\n}\r\n\r\n.animate-in {\n  animation-name: enter;\n  animation-duration: 150ms;\n  --tw-enter-opacity: initial;\n  --tw-enter-scale: initial;\n  --tw-enter-rotate: initial;\n  --tw-enter-translate-x: initial;\n  --tw-enter-translate-y: initial;\n}\r\n\r\n.fade-in {\n  --tw-enter-opacity: 0;\n}\r\n\r\n.fade-in-0 {\n  --tw-enter-opacity: 0;\n}\r\n\r\n.zoom-in-95 {\n  --tw-enter-scale: .95;\n}\r\n\r\n.slide-in-from-bottom-2 {\n  --tw-enter-translate-y: 0.5rem;\n}\r\n\r\n.slide-in-from-bottom-4 {\n  --tw-enter-translate-y: 1rem;\n}\r\n\r\n.slide-in-from-right {\n  --tw-enter-translate-x: 100%;\n}\r\n\r\n.slide-in-from-top-2 {\n  --tw-enter-translate-y: -0.5rem;\n}\r\n\r\n.slide-in-from-top-4 {\n  --tw-enter-translate-y: -1rem;\n}\r\n\r\n.duration-100 {\n  animation-duration: 100ms;\n}\r\n\r\n.duration-150 {\n  animation-duration: 150ms;\n}\r\n\r\n.duration-200 {\n  animation-duration: 200ms;\n}\r\n\r\n.duration-300 {\n  animation-duration: 300ms;\n}\r\n\r\n.duration-500 {\n  animation-duration: 500ms;\n}\r\n\r\n.duration-700 {\n  animation-duration: 700ms;\n}\r\n\r\n.ease-in-out {\n  animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n}\r\n\r\n.ease-linear {\n  animation-timing-function: linear;\n}\r\n\r\n.ease-out {\n  animation-timing-function: cubic-bezier(0, 0, 0.2, 1);\n}\r\n\r\n.ease-smooth {\n  animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n}\r\n\r\n.running {\n  animation-play-state: running;\n}\r\n\r\n/* Display sizes - Hero sections, marketing */\r\n\r\n/* Heading sizes - Page titles, sections */\r\n\r\n/* Body text - Fluid paragraph sizes */\r\n\r\n/* Container query containers */\r\n\r\n/* Minimum touch target sizes */\r\n\r\n/* Touch-friendly padding for inline elements */\r\n\r\n/* Reset touch targets on desktop */\r\n\r\n/* Responsive image containers */\r\n\r\n/* Aspect ratio containers for images */\r\n\r\n/* Lazy loading placeholder */\r\n\r\n.img-lazy {\r\n    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);\r\n    background-size: 200% 100%;\r\n    animation: shimmer 1.5s infinite;\r\n  }\r\n\r\n.dark .img-lazy {\r\n    background: linear-gradient(90deg, #374151 25%, #4b5563 50%, #374151 75%);\r\n    background-size: 200% 100%;\r\n  }\r\n\r\n.pb-safe {\r\n    padding-bottom: env(safe-area-inset-bottom, 0);\r\n  }\r\n\r\n/* Responsive gap utilities */\r\n\r\n/* Responsive padding utilities */\r\n\r\n/* =============================================================\r\n   shadcn/ui Design System CSS Variables\r\n   Provides semantic color tokens for the component library\r\n   ============================================================= */\r\n\r\n/* Base body styles for shadcn/ui compatibility */\r\n\r\n@keyframes fadeInUp {\r\n  from {\r\n    opacity: 0;\r\n    transform: translateY(30px);\r\n  }\r\n  to {\r\n    opacity: 1;\r\n    transform: translateY(0);\r\n  }\r\n}\r\n\r\n@keyframes fadeIn {\r\n  from {\r\n    opacity: 0;\r\n  }\r\n  to {\r\n    opacity: 1;\r\n  }\r\n}\r\n\r\n@keyframes slideInLeft {\r\n  from {\r\n    opacity: 0;\r\n    transform: translateX(-30px);\r\n  }\r\n  to {\r\n    opacity: 1;\r\n    transform: translateX(0);\r\n  }\r\n}\r\n\r\n@keyframes slideInRight {\r\n  from {\r\n    opacity: 0;\r\n    transform: translateX(30px);\r\n  }\r\n  to {\r\n    opacity: 1;\r\n    transform: translateX(0);\r\n  }\r\n}\r\n\r\n@keyframes scaleIn {\r\n  from {\r\n    opacity: 0;\r\n    transform: scale(0.9);\r\n  }\r\n  to {\r\n    opacity: 1;\r\n    transform: scale(1);\r\n  }\r\n}\r\n\r\n@keyframes shimmer {\r\n  0% {\r\n    transform: translateX(-100%);\r\n  }\r\n  100% {\r\n    transform: translateX(100%);\r\n  }\r\n}\r\n\r\n.animate-shimmer {\r\n  animation: shimmer 2s infinite;\r\n}\r\n\r\n.animate-fade-in-up {\r\n  animation: fadeInUp 0.6s ease-out forwards;\r\n}\r\n\r\n.animate-fade-in {\r\n  animation: fadeIn 0.8s ease-out forwards;\r\n}\r\n\r\n.animate-fadeIn {\r\n  animation: fadeIn 0.5s ease-out forwards;\r\n}\r\n\r\n.animate-slide-in-left {\r\n  animation: slideInLeft 0.6s ease-out forwards;\r\n}\r\n\r\n.animate-slide-in-right {\r\n  animation: slideInRight 0.6s ease-out forwards;\r\n}\r\n\r\n.animate-scale-in {\r\n  animation: scaleIn 0.5s ease-out forwards;\r\n}\r\n\r\n.animation-delay-100 {\r\n  animation-delay: 0.1s;\r\n  opacity: 0;\r\n}\r\n\r\n.animation-delay-200 {\r\n  animation-delay: 0.2s;\r\n  opacity: 0;\r\n}\r\n\r\n.animation-delay-300 {\r\n  animation-delay: 0.3s;\r\n  opacity: 0;\r\n}\r\n\r\n.animation-delay-400 {\r\n  animation-delay: 0.4s;\r\n  opacity: 0;\r\n}\r\n\r\n.animation-delay-500 {\r\n  animation-delay: 0.5s;\r\n  opacity: 0;\r\n}\r\n\r\n/* Auth illustration ambient animations (only when .illus-animate is present; respects reduced motion via class) */\r\n\r\n@keyframes illus-float-subtle {\r\n  0%,\r\n  100% {\r\n    transform: scale(1) translate(0, 0);\r\n  }\r\n  50% {\r\n    transform: scale(1.03) translate(2px, -2px);\r\n  }\r\n}\r\n\r\n@keyframes illus-float-person {\r\n  0%,\r\n  100% {\r\n    transform: translate(0, 0);\r\n  }\r\n  50% {\r\n    transform: translate(1px, 2px);\r\n  }\r\n}\r\n\r\n@keyframes illus-pulse-dots {\r\n  0%,\r\n  100% {\r\n    opacity: 1;\r\n  }\r\n  50% {\r\n    opacity: 0.6;\r\n  }\r\n}\r\n\r\n@keyframes illus-pulse-soft {\r\n  0%,\r\n  100% {\r\n    transform: scale(1);\r\n    opacity: 1;\r\n  }\r\n  50% {\r\n    transform: scale(1.02);\r\n    opacity: 0.95;\r\n  }\r\n}\r\n\r\n.illus-animate #illus-bg-circle {\r\n  animation: illus-float-subtle 9s ease-in-out infinite;\r\n}\r\n\r\n.illus-animate #illus-person {\r\n  animation: illus-float-person 5s ease-in-out infinite;\r\n}\r\n\r\n.illus-animate #illus-bubble-dots {\r\n  animation: illus-pulse-dots 1.5s ease-in-out infinite;\r\n}\r\n\r\n.illus-animate #illus-device {\r\n  animation: illus-pulse-soft 3s ease-in-out infinite;\r\n}\r\n\r\n/* Hide scrollbar for plan sidebar but keep functionality */\r\n\r\n.plan-sidebar {\r\n  scrollbar-width: none; /* Firefox */\r\n  -ms-overflow-style: none; /* IE and Edge */\r\n}\r\n\r\n.plan-sidebar::-webkit-scrollbar {\r\n  display: none; /* Chrome, Safari, Opera */\r\n  width: 0;\r\n  height: 0;\r\n}\r\n\r\n/* Optional: Show thin scrollbar on hover for better UX */\r\n\r\n.plan-sidebar:hover {\r\n  scrollbar-width: thin; /* Firefox */\r\n}\r\n\r\n.plan-sidebar:hover::-webkit-scrollbar {\r\n  display: block;\r\n  width: 4px;\r\n}\r\n\r\n.plan-sidebar:hover::-webkit-scrollbar-track {\r\n  background: transparent;\r\n}\r\n\r\n.plan-sidebar:hover::-webkit-scrollbar-thumb {\r\n  background-color: rgba(156, 163, 175, 0.5);\r\n  border-radius: 4px;\r\n}\r\n\r\n.dark .plan-sidebar:hover::-webkit-scrollbar-thumb {\r\n  background-color: rgba(107, 114, 128, 0.5);\r\n}\r\n\r\n/* =============================================================\r\n   Prose Warm - Optimal reading typography for preview page\r\n   Notion-style warm grays and generous spacing\r\n   ============================================================= */\r\n\r\n.prose-warm {\r\n  font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\r\n  font-size: 1.125rem; /* 18px base */\r\n  line-height: 1.75;\r\n  color: #374151; /* warm gray-700 */\r\n  letter-spacing: -0.01em;\r\n}\r\n\r\n.dark .prose-warm {\r\n  color: #E5E7EB; /* gray-200 */\r\n}\r\n\r\n/* Headings */\r\n\r\n.prose-warm h1,\r\n.prose-warm-content h1 {\r\n  font-size: 2rem;\r\n  font-weight: 700;\r\n  line-height: 1.2;\r\n  margin-top: 2.5rem;\r\n  margin-bottom: 1rem;\r\n  color: #1F2937;\r\n  letter-spacing: -0.02em;\r\n}\r\n\r\n.prose-warm h2,\r\n.prose-warm-content h2 {\r\n  font-size: 1.5rem;\r\n  font-weight: 600;\r\n  line-height: 1.3;\r\n  margin-top: 2rem;\r\n  margin-bottom: 0.75rem;\r\n  color: #1F2937;\r\n  letter-spacing: -0.01em;\r\n}\r\n\r\n.prose-warm h3,\r\n.prose-warm-content h3 {\r\n  font-size: 1.25rem;\r\n  font-weight: 600;\r\n  line-height: 1.4;\r\n  margin-top: 1.5rem;\r\n  margin-bottom: 0.5rem;\r\n  color: #1F2937;\r\n}\r\n\r\n.prose-warm h4,\r\n.prose-warm-content h4 {\r\n  font-size: 1.125rem;\r\n  font-weight: 600;\r\n  line-height: 1.4;\r\n  margin-top: 1.25rem;\r\n  margin-bottom: 0.5rem;\r\n  color: #1F2937;\r\n}\r\n\r\n.dark .prose-warm h1,\r\n.dark .prose-warm h2,\r\n.dark .prose-warm h3,\r\n.dark .prose-warm h4,\r\n.dark .prose-warm-content h1,\r\n.dark .prose-warm-content h2,\r\n.dark .prose-warm-content h3,\r\n.dark .prose-warm-content h4 {\r\n  color: #F9FAFB;\r\n}\r\n\r\n/* Paragraphs */\r\n\r\n.prose-warm p,\r\n.prose-warm-content p {\r\n  margin-bottom: 1.25rem;\r\n}\r\n\r\n.prose-warm p:last-child,\r\n.prose-warm-content p:last-child {\r\n  margin-bottom: 0;\r\n}\r\n\r\n/* Lists */\r\n\r\n.prose-warm ul,\r\n.prose-warm ol,\r\n.prose-warm-content ul,\r\n.prose-warm-content ol {\r\n  margin: 1.25rem 0;\r\n  padding-left: 1.5rem;\r\n}\r\n\r\n.prose-warm li,\r\n.prose-warm-content li {\r\n  margin-bottom: 0.5rem;\r\n}\r\n\r\n.prose-warm ul,\r\n.prose-warm-content ul {\r\n  list-style-type: disc;\r\n}\r\n\r\n.prose-warm ol,\r\n.prose-warm-content ol {\r\n  list-style-type: decimal;\r\n}\r\n\r\n/* Strong and emphasis */\r\n\r\n.prose-warm strong,\r\n.prose-warm-content strong {\r\n  font-weight: 600;\r\n  color: #1F2937;\r\n}\r\n\r\n.dark .prose-warm strong,\r\n.dark .prose-warm-content strong {\r\n  color: #F9FAFB;\r\n}\r\n\r\n.prose-warm em,\r\n.prose-warm-content em {\r\n  font-style: italic;\r\n}\r\n\r\n/* Links */\r\n\r\n.prose-warm a,\r\n.prose-warm-content a {\r\n  color: #FF6B00;\r\n  text-decoration: underline;\r\n  text-underline-offset: 2px;\r\n}\r\n\r\n.prose-warm a:hover,\r\n.prose-warm-content a:hover {\r\n  color: #E55F00;\r\n}\r\n\r\n/* Blockquotes */\r\n\r\n.prose-warm blockquote,\r\n.prose-warm-content blockquote {\r\n  border-left: 3px solid #FF6B00;\r\n  padding-left: 1rem;\r\n  margin: 1.5rem 0;\r\n  color: #6B7280;\r\n  font-style: italic;\r\n}\r\n\r\n.dark .prose-warm blockquote,\r\n.dark .prose-warm-content blockquote {\r\n  color: #9CA3AF;\r\n}\r\n\r\n/* Code */\r\n\r\n.prose-warm code,\r\n.prose-warm-content code {\r\n  font-family: 'SF Mono', 'Fira Code', monospace;\r\n  font-size: 0.875em;\r\n  background-color: #F3F4F6;\r\n  padding: 0.125rem 0.375rem;\r\n  border-radius: 0.25rem;\r\n}\r\n\r\n.dark .prose-warm code,\r\n.dark .prose-warm-content code {\r\n  background-color: #374151;\r\n}\r\n\r\n/* Horizontal rule */\r\n\r\n.prose-warm hr,\r\n.prose-warm-content hr {\r\n  border: none;\r\n  height: 1px;\r\n  background: linear-gradient(to right, transparent, #E5E7EB, transparent);\r\n  margin: 2rem 0;\r\n}\r\n\r\n.dark .prose-warm hr,\r\n.dark .prose-warm-content hr {\r\n  background: linear-gradient(to right, transparent, #374151, transparent);\r\n}\r\n\r\n/* Professional Business Plan Table Styles */\r\n\r\n.business-plan-table {\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n  margin: 1.5rem 0;\r\n  font-size: 0.875rem;\r\n  border: 1px solid #e5e7eb;\r\n  border-radius: 0.5rem;\r\n  overflow: hidden;\r\n}\r\n\r\n.business-plan-table thead {\r\n  background-color: #1A2B47;\r\n  color: white;\r\n}\r\n\r\n.business-plan-table th {\r\n  padding: 0.875rem 1rem;\r\n  text-align: left;\r\n  font-weight: 600;\r\n  font-size: 0.8125rem;\r\n  text-transform: uppercase;\r\n  letter-spacing: 0.025em;\r\n  border-bottom: 2px solid #1A2B47;\r\n}\r\n\r\n.business-plan-table td {\r\n  padding: 0.75rem 1rem;\r\n  border-bottom: 1px solid #e5e7eb;\r\n  vertical-align: top;\r\n}\r\n\r\n.business-plan-table tbody tr:nth-child(even) {\r\n  background-color: #f9fafb;\r\n}\r\n\r\n.business-plan-table tbody tr:hover {\r\n  background-color: #f3f4f6;\r\n}\r\n\r\n.business-plan-table tbody tr:last-child td {\r\n  border-bottom: none;\r\n}\r\n\r\n/* Footer row styling (like \"Total required\") */\r\n\r\n.business-plan-table tfoot tr,\r\n.business-plan-table tbody tr.table-footer {\r\n  background-color: #1A2B47 !important;\r\n  color: white;\r\n  font-weight: 600;\r\n}\r\n\r\n.business-plan-table tfoot td,\r\n.business-plan-table tbody tr.table-footer td {\r\n  border-bottom: none;\r\n}\r\n\r\n/* Additional info row */\r\n\r\n.business-plan-table tbody tr.additional-info {\r\n  background-color: #f0f4f8;\r\n}\r\n\r\n.business-plan-table tbody tr.additional-info td {\r\n  padding: 1rem;\r\n  font-style: italic;\r\n  color: #4b5563;\r\n}\r\n\r\n/* Currency/number alignment */\r\n\r\n.business-plan-table td.currency,\r\n.business-plan-table th.currency {\r\n  text-align: right;\r\n}\r\n\r\n/* Dark mode adjustments */\r\n\r\n.dark .business-plan-table {\r\n  border-color: #374151;\r\n}\r\n\r\n.dark .business-plan-table thead {\r\n  background-color: #1f2937;\r\n}\r\n\r\n.dark .business-plan-table th {\r\n  border-bottom-color: #4b5563;\r\n}\r\n\r\n.dark .business-plan-table td {\r\n  border-bottom-color: #374151;\r\n}\r\n\r\n.dark .business-plan-table tbody tr:nth-child(even) {\r\n  background-color: #1f2937;\r\n}\r\n\r\n.dark .business-plan-table tbody tr:hover {\r\n  background-color: #374151;\r\n}\r\n\r\n.dark .business-plan-table tfoot tr,\r\n.dark .business-plan-table tbody tr.table-footer {\r\n  background-color: #374151 !important;\r\n}\r\n\r\n.dark .business-plan-table tbody tr.additional-info {\r\n  background-color: #1f2937;\r\n}\r\n\r\n.dark .business-plan-table tbody tr.additional-info td {\r\n  color: #9ca3af;\r\n}\r\n\r\n/* Simple two-column table (like funding requirements) */\r\n\r\n.business-plan-table.two-column td:first-child {\r\n  width: 70%;\r\n}\r\n\r\n.business-plan-table.two-column td:last-child {\r\n  width: 30%;\r\n  text-align: right;\r\n  font-weight: 500;\r\n}\r\n\r\n/* Business Plan Section Footer */\r\n\r\n.plan-section-footer {\r\n  margin-top: 3rem;\r\n  padding-top: 1.5rem;\r\n  border-top: 1px solid #e5e7eb;\r\n  text-align: center;\r\n}\r\n\r\n.plan-section-footer .company-name {\r\n  font-size: 0.875rem;\r\n  color: #6b7280;\r\n  font-style: italic;\r\n}\r\n\r\n.plan-section-footer .company-name strong {\r\n  color: #1A2B47;\r\n  font-weight: 600;\r\n}\r\n\r\n.dark .plan-section-footer {\r\n  border-top-color: #374151;\r\n}\r\n\r\n.dark .plan-section-footer .company-name {\r\n  color: #9ca3af;\r\n}\r\n\r\n.dark .plan-section-footer .company-name strong {\r\n  color: #f3f4f6;\r\n}\r\n\r\n/* Rich text content table styles */\r\n\r\n.rich-text-content table {\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n  margin: 1.5rem 0;\r\n  font-size: 0.875rem;\r\n  border: 1px solid #e5e7eb;\r\n  border-radius: 0.5rem;\r\n  overflow: hidden;\r\n}\r\n\r\n.rich-text-content table thead {\r\n  background-color: #1A2B47;\r\n  color: white;\r\n}\r\n\r\n.rich-text-content table th {\r\n  padding: 0.875rem 1rem;\r\n  text-align: left;\r\n  font-weight: 600;\r\n  font-size: 0.8125rem;\r\n  border-bottom: 2px solid #1A2B47;\r\n}\r\n\r\n.rich-text-content table td {\r\n  padding: 0.75rem 1rem;\r\n  border-bottom: 1px solid #e5e7eb;\r\n  vertical-align: top;\r\n}\r\n\r\n.rich-text-content table tbody tr:nth-child(even) {\r\n  background-color: #f9fafb;\r\n}\r\n\r\n.rich-text-content table tbody tr:hover {\r\n  background-color: #f3f4f6;\r\n}\r\n\r\n.dark .rich-text-content table {\r\n  border-color: #374151;\r\n}\r\n\r\n.dark .rich-text-content table thead {\r\n  background-color: #1f2937;\r\n}\r\n\r\n.dark .rich-text-content table th {\r\n  border-bottom-color: #4b5563;\r\n  color: white;\r\n}\r\n\r\n.dark .rich-text-content table td {\r\n  border-bottom-color: #374151;\r\n}\r\n\r\n.dark .rich-text-content table tbody tr:nth-child(even) {\r\n  background-color: #1f2937;\r\n}\r\n\r\n.dark .rich-text-content table tbody tr:hover {\r\n  background-color: #374151;\r\n}\r\n\r\n/* Reduced motion support for accessibility */\r\n\r\n@media (prefers-reduced-motion: reduce) {\r\n  *,\r\n  *::before,\r\n  *::after {\r\n    animation-duration: 0.01ms !important;\r\n    animation-iteration-count: 1 !important;\r\n    transition-duration: 0.01ms !important;\r\n    scroll-behavior: auto !important;\r\n  }\r\n\r\n  .animate-spin,\r\n  .animate-pulse,\r\n  .animate-bounce,\r\n  .animate-fade-in,\r\n  .animate-fadeIn,\r\n  .animate-fade-in-up,\r\n  .animate-slide-in-left,\r\n  .animate-slide-in-right,\r\n  .animate-scale-in {\r\n    animation: none !important;\r\n    opacity: 1 !important;\r\n    transform: none !important;\r\n  }\r\n}\r\n\r\n/* Screen reader only utility class */\r\n\r\n.sr-only {\r\n  position: absolute;\r\n  width: 1px;\r\n  height: 1px;\r\n  padding: 0;\r\n  margin: -1px;\r\n  overflow: hidden;\r\n  clip: rect(0, 0, 0, 0);\r\n  white-space: nowrap;\r\n  border: 0;\r\n}\r\n\r\n/* Counteract sr-only for focus states */\r\n\r\n.not-sr-only {\r\n  position: static;\r\n  width: auto;\r\n  height: auto;\r\n  padding: 0;\r\n  margin: 0;\r\n  overflow: visible;\r\n  clip: auto;\r\n  white-space: normal;\r\n}\r\n\r\n/* Unused brand utilities removed — all components now use Tailwind tokens\r\n   (text-strategy-blue, text-momentum-orange, bg-white dark:bg-gray-800, etc.)\r\n   and shadcn/ui CSS variables instead of custom .text-brand-*, .bg-brand-*,\r\n   .btn-brand-*, .card-brand, .feature-card, .glass-card, .hero-gradient-*,\r\n   .grid-pattern, .card-hover-lift, .section-brand-*, .stagger-* classes. */\r\n\r\n/* =============================================================\r\n   ProseMirror / Tiptap Rich Text Editor Styles\r\n   ============================================================= */\r\n\r\n/* Editor container and base styles */\r\n\r\n.prose-editor {\r\n  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\r\n  font-size: 1rem;\r\n  line-height: 1.75;\r\n  color: #1f2937;\r\n}\r\n\r\n.dark .prose-editor {\r\n  color: #f3f4f6;\r\n}\r\n\r\n/* Placeholder styling */\r\n\r\n.prose-editor p.is-editor-empty:first-child::before {\r\n  content: attr(data-placeholder);\r\n  float: left;\r\n  color: #9ca3af;\r\n  pointer-events: none;\r\n  height: 0;\r\n}\r\n\r\n.dark .prose-editor p.is-editor-empty:first-child::before {\r\n  color: #6b7280;\r\n}\r\n\r\n/* Paragraph spacing */\r\n\r\n.prose-editor p {\r\n  margin-top: 0;\r\n  margin-bottom: 1rem;\r\n}\r\n\r\n/* Heading styles */\r\n\r\n.prose-editor h1 {\r\n  font-size: 2rem;\r\n  font-weight: 700;\r\n  line-height: 1.25;\r\n  margin-top: 1.5rem;\r\n  margin-bottom: 1rem;\r\n  color: #111827;\r\n}\r\n\r\n.dark .prose-editor h1 {\r\n  color: #f9fafb;\r\n}\r\n\r\n.prose-editor h2 {\r\n  font-size: 1.5rem;\r\n  font-weight: 600;\r\n  line-height: 1.3;\r\n  margin-top: 1.25rem;\r\n  margin-bottom: 0.75rem;\r\n  color: #1f2937;\r\n}\r\n\r\n.dark .prose-editor h2 {\r\n  color: #f3f4f6;\r\n}\r\n\r\n.prose-editor h3 {\r\n  font-size: 1.25rem;\r\n  font-weight: 600;\r\n  line-height: 1.4;\r\n  margin-top: 1rem;\r\n  margin-bottom: 0.5rem;\r\n  color: #374151;\r\n}\r\n\r\n.dark .prose-editor h3 {\r\n  color: #e5e7eb;\r\n}\r\n\r\n/* Bold, italic, underline */\r\n\r\n.prose-editor strong {\r\n  font-weight: 600;\r\n}\r\n\r\n.prose-editor em {\r\n  font-style: italic;\r\n}\r\n\r\n.prose-editor u {\r\n  text-decoration: underline;\r\n}\r\n\r\n.prose-editor s {\r\n  text-decoration: line-through;\r\n}\r\n\r\n/* List styles */\r\n\r\n.prose-editor ul {\r\n  list-style-type: disc;\r\n  padding-left: 1.5rem;\r\n  margin-top: 0.5rem;\r\n  margin-bottom: 1rem;\r\n}\r\n\r\n.prose-editor ol {\r\n  list-style-type: decimal;\r\n  padding-left: 1.5rem;\r\n  margin-top: 0.5rem;\r\n  margin-bottom: 1rem;\r\n}\r\n\r\n.prose-editor li {\r\n  margin-top: 0.25rem;\r\n  margin-bottom: 0.25rem;\r\n}\r\n\r\n.prose-editor li p {\r\n  margin: 0;\r\n}\r\n\r\n/* Nested lists */\r\n\r\n.prose-editor ul ul,\r\n.prose-editor ol ul {\r\n  list-style-type: circle;\r\n  margin-top: 0.25rem;\r\n  margin-bottom: 0.25rem;\r\n}\r\n\r\n.prose-editor ul ul ul,\r\n.prose-editor ol ul ul,\r\n.prose-editor ul ol ul,\r\n.prose-editor ol ol ul {\r\n  list-style-type: square;\r\n}\r\n\r\n.prose-editor ul ol,\r\n.prose-editor ol ol {\r\n  list-style-type: lower-alpha;\r\n  margin-top: 0.25rem;\r\n  margin-bottom: 0.25rem;\r\n}\r\n\r\n/* Blockquote styling */\r\n\r\n.prose-editor blockquote {\r\n  border-left: 4px solid #d1d5db;\r\n  padding-left: 1rem;\r\n  margin-left: 0;\r\n  margin-right: 0;\r\n  margin-top: 1rem;\r\n  margin-bottom: 1rem;\r\n  font-style: italic;\r\n  color: #4b5563;\r\n}\r\n\r\n.dark .prose-editor blockquote {\r\n  border-left-color: #4b5563;\r\n  color: #9ca3af;\r\n}\r\n\r\n/* Horizontal rule */\r\n\r\n.prose-editor hr {\r\n  border: none;\r\n  border-top: 2px solid #e5e7eb;\r\n  margin-top: 1.5rem;\r\n  margin-bottom: 1.5rem;\r\n}\r\n\r\n.dark .prose-editor hr {\r\n  border-top-color: #4b5563;\r\n}\r\n\r\n/* Link styling */\r\n\r\n.prose-editor a {\r\n  color: #2563eb;\r\n  text-decoration: underline;\r\n  cursor: pointer;\r\n}\r\n\r\n.prose-editor a:hover {\r\n  color: #1d4ed8;\r\n}\r\n\r\n.dark .prose-editor a {\r\n  color: #60a5fa;\r\n}\r\n\r\n.dark .prose-editor a:hover {\r\n  color: #93c5fd;\r\n}\r\n\r\n/* Code and preformatted text (if added later) */\r\n\r\n.prose-editor code {\r\n  background-color: #f3f4f6;\r\n  padding: 0.125rem 0.375rem;\r\n  border-radius: 0.25rem;\r\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;\r\n  font-size: 0.875em;\r\n}\r\n\r\n.dark .prose-editor code {\r\n  background-color: #374151;\r\n}\r\n\r\n.prose-editor pre {\r\n  background-color: #1f2937;\r\n  color: #f3f4f6;\r\n  padding: 1rem;\r\n  border-radius: 0.5rem;\r\n  overflow-x: auto;\r\n  margin-top: 1rem;\r\n  margin-bottom: 1rem;\r\n}\r\n\r\n.prose-editor pre code {\r\n  background-color: transparent;\r\n  padding: 0;\r\n  border-radius: 0;\r\n  font-size: 0.875rem;\r\n}\r\n\r\n/* Focus styles for editor content area */\r\n\r\n.ProseMirror:focus {\r\n  outline: none;\r\n}\r\n\r\n/* Selection styling */\r\n\r\n.prose-editor ::-moz-selection {\r\n  background-color: #fde68a;\r\n}\r\n\r\n.prose-editor ::selection {\r\n  background-color: #fde68a;\r\n}\r\n\r\n.dark .prose-editor ::-moz-selection {\r\n  background-color: #78350f;\r\n}\r\n\r\n.dark .prose-editor ::selection {\r\n  background-color: #78350f;\r\n}\r\n\r\n/* =============================================================\r\n   CMS Custom Scrollbar Styles\r\n   ============================================================= */\r\n\r\n.custom-scrollbar::-webkit-scrollbar {\r\n  width: 6px;\r\n  height: 6px;\r\n}\r\n\r\n.custom-scrollbar::-webkit-scrollbar-track {\r\n  background: transparent;\r\n}\r\n\r\n.custom-scrollbar::-webkit-scrollbar-thumb {\r\n  background: #e5e7eb;\r\n  border-radius: 10px;\r\n}\r\n\r\n.custom-scrollbar::-webkit-scrollbar-thumb:hover {\r\n  background: #d1d5db;\r\n}\r\n\r\n.dark .custom-scrollbar::-webkit-scrollbar-thumb {\r\n  background: #4b5563;\r\n}\r\n\r\n.dark .custom-scrollbar::-webkit-scrollbar-thumb:hover {\r\n  background: #6b7280;\r\n}\r\n\r\n/* Firefox scrollbar */\r\n\r\n.custom-scrollbar {\r\n  scrollbar-width: thin;\r\n  scrollbar-color: #e5e7eb transparent;\r\n}\r\n\r\n.dark .custom-scrollbar {\r\n  scrollbar-color: #4b5563 transparent;\r\n}\r\n\r\n/* =============================================================\r\n   Material Symbols Settings\r\n   ============================================================= */\r\n\r\n.material-symbols-outlined {\r\n  font-variation-settings:\r\n    'FILL' 0,\r\n    'wght' 400,\r\n    'GRAD' 0,\r\n    'opsz' 24;\r\n}\r\n\r\n/* =============================================================\r\n   Fluid Typography System\r\n   Smooth scaling between mobile (320px) and desktop (1280px)\r\n   using clamp() for seamless responsive typography\r\n   ============================================================= */\r\n\r\n/* =============================================================\r\n   Container Queries Support\r\n   Modern responsive design based on container size\r\n   ============================================================= */\r\n\r\n/* Container query responsive utilities */\r\n\r\n@container (min-width: 320px) {\r\n  .cq-xs\\:block { display: block; }\r\n  .cq-xs\\:hidden { display: none; }\r\n  .cq-xs\\:flex { display: flex; }\r\n  .cq-xs\\:grid { display: grid; }\r\n}\r\n\r\n@container (min-width: 480px) {\r\n  .cq-sm\\:block { display: block; }\r\n  .cq-sm\\:hidden { display: none; }\r\n  .cq-sm\\:flex { display: flex; }\r\n  .cq-sm\\:grid { display: grid; }\r\n  .cq-sm\\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n}\r\n\r\n@container (min-width: 640px) {\r\n  .cq-md\\:block { display: block; }\r\n  .cq-md\\:hidden { display: none; }\r\n  .cq-md\\:flex { display: flex; }\r\n  .cq-md\\:grid { display: grid; }\r\n  .cq-md\\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n  .cq-md\\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n}\r\n\r\n@container (min-width: 768px) {\r\n  .cq-lg\\:block { display: block; }\r\n  .cq-lg\\:hidden { display: none; }\r\n  .cq-lg\\:flex { display: flex; }\r\n  .cq-lg\\:grid { display: grid; }\r\n  .cq-lg\\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n  .cq-lg\\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n  .cq-lg\\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }\r\n}\r\n\r\n/* =============================================================\r\n   Touch Target Utilities\r\n   WCAG 2.5.5 compliant touch targets (44x44px minimum)\r\n   ============================================================= */\r\n\r\n/* =============================================================\r\n   Responsive Image Utilities\r\n   Optimized loading and display for different viewports\r\n   ============================================================= */\r\n\r\n/* =============================================================\r\n   Safe Area Utilities (for notched devices)\r\n   ============================================================= */\r\n\r\n/* =============================================================\r\n   Mobile-first Spacing Utilities\r\n   ============================================================= */\r\n\r\n.marker\\:text-orange-500 *::marker {\n  color: rgb(249 115 22 );\n}\r\n\r\n.marker\\:text-orange-500::marker {\n  color: rgb(249 115 22 );\n}\r\n\r\n.file\\:border-0::file-selector-button {\n  border-width: 0px;\n}\r\n\r\n.file\\:bg-transparent::file-selector-button {\n  background-color: transparent;\n}\r\n\r\n.file\\:text-sm::file-selector-button {\n  font-size: 0.875rem;\n  line-height: 1.25rem;\n}\r\n\r\n.file\\:font-medium::file-selector-button {\n  font-weight: 500;\n}\r\n\r\n.file\\:text-foreground::file-selector-button {\n  color: hsl(var(--foreground));\n}\r\n\r\n.placeholder\\:text-gray-400::-moz-placeholder {\n  --tw-text-opacity: 1;\n  color: rgb(156 163 175 / var(--tw-text-opacity, 1));\n}\r\n\r\n.placeholder\\:text-gray-400::placeholder {\n  --tw-text-opacity: 1;\n  color: rgb(156 163 175 / var(--tw-text-opacity, 1));\n}\r\n\r\n.placeholder\\:text-muted-foreground::-moz-placeholder {\n  color: hsl(var(--muted-foreground));\n}\r\n\r\n.placeholder\\:text-muted-foreground::placeholder {\n  color: hsl(var(--muted-foreground));\n}\r\n\r\n.placeholder\\:text-slate-400::-moz-placeholder {\n  --tw-text-opacity: 1;\n  color: rgb(148 163 184 / var(--tw-text-opacity, 1));\n}\r\n\r\n.placeholder\\:text-slate-400::placeholder {\n  --tw-text-opacity: 1;\n  color: rgb(148 163 184 / var(--tw-text-opacity, 1));\n}\r\n\r\n.placeholder\\:text-warm-gray-400::-moz-placeholder {\n  --tw-text-opacity: 1;\n  color: rgb(163 163 163 / var(--tw-text-opacity, 1));\n}\r\n\r\n.placeholder\\:text-warm-gray-400::placeholder {\n  --tw-text-opacity: 1;\n  color: rgb(163 163 163 / var(--tw-text-opacity, 1));\n}\r\n\r\n.after\\:absolute::after {\n  content: var(--tw-content);\n  position: absolute;\n}\r\n\r\n.after\\:-inset-2::after {\n  content: var(--tw-content);\n  inset: -0.5rem;\n}\r\n\r\n.after\\:inset-y-0::after {\n  content: var(--tw-content);\n  top: 0px;\n  bottom: 0px;\n}\r\n\r\n.after\\:left-1\\/2::after {\n  content: var(--tw-content);\n  left: 50%;\n}\r\